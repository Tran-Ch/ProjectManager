﻿@using ProjectManager.ASPMVC.Handlers
@inject UserSessionManager UserSession

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Project Manager</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjectManager.ASPMVC.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="page">
        @if (UserSession.IsAuthenticated)
        {
            <header class="topbar">
                <div class="topbar-left">
                    <strong>Bienvenue, @UserSession.FullName</strong>
                </div>

                <div class="topbar-right">
                    @if (UserSession.IsProjectManager)
                    {
                        <a asp-controller="Project"
                           asp-action="Create"
                           class="btn btn-success">
                            + Créer Projet
                        </a>
                    }

                    <a asp-controller="Project" asp-action="Index" class="top-link">Projets</a>
                    <a asp-controller="Post" asp-action="Index" class="top-link posts-link">
                        Posts
                        @if (ViewBag.PostCount is int postCount && postCount > 0)
                        {
                            <span class="badge">@postCount</span>
                        }
                    </a>
                    <a asp-controller="Auth" asp-action="Logout" class="btn btn-logout">Déconnexion</a>
                </div>
            </header>
        }

        <main class="main-content">
            @RenderBody()
        </main>

        <footer class="footer">
            ProjectManager - Interface 3 - 2026
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>