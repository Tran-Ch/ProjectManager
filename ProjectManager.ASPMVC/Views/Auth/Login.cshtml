@model ProjectManager.ASPMVC.Models.Auth.LoginForm

@{
    ViewData["Title"] = "Connexion";
}

<h2 class="subtitle">Connexion</h2>

<div class="section-box">
    <div class="form-card mx-auto" style="max-width: 520px;">
        <form asp-action="Login" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="label"></label>
                <input asp-for="Email" class="input" />
                <span asp-validation-for="Email" class="validation"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="label"></label>
                <input asp-for="Password" class="input" />
                <span asp-validation-for="Password" class="validation"></span>
            </div>

            <div class="actions">
                <button type="submit" class="btn btn-primary">Se connecter</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}